generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum EligibilityStatus {
  ELIGIBLE
  NOT_ELIGIBLE
}

enum SwipeDirection {
  LEFT
  RIGHT
}

enum ApplicationStatus {
  APPLIED
  FAILED
  PENDING
}

// ──────────────────────────────────────────────
// Models
// ──────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  profile      Profile?
  resumes      Resume[]
  swipeActions SwipeAction[]
  applications Application[]

  @@map("users")
}

model Profile {
  userId          String   @id @map("user_id")
  name            String
  phone           String?
  links           Json?
  preferencesJson Json?    @map("preferences_json")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Resume {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  filename    String
  storagePath String   @map("storage_path")
  fileSize    Int?     @map("file_size")
  isMaster    Boolean  @default(false) @map("is_master")
  createdAt   DateTime @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications Application[]

  @@index([userId])
  @@map("resumes")
}

model Job {
  id                String            @id @default(uuid())
  source            String
  company           String
  title             String
  location          String?
  summary           String?
  url               String?
  eligibilityStatus EligibilityStatus @map("eligibility_status")
  createdAt         DateTime          @default(now()) @map("created_at")

  swipeActions SwipeAction[]
  applications Application[]

  @@unique([title, company])
  @@map("jobs")
}

model SwipeAction {
  id        String         @id @default(uuid())
  userId    String         @map("user_id")
  jobId     String         @map("job_id")
  action    SwipeDirection
  createdAt DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([jobId])
  @@map("swipe_actions")
}

model Application {
  id        String            @id @default(uuid())
  userId    String            @map("user_id")
  jobId     String            @map("job_id")
  resumeId  String            @map("resume_id")
  status    ApplicationStatus
  appliedAt DateTime          @default(now()) @map("applied_at")

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job            Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resume         Resume           @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  submissionLogs SubmissionLog[]

  @@index([userId])
  @@index([jobId])
  @@index([resumeId])
  @@map("applications")
}

model SubmissionLog {
  id            String   @id @default(uuid())
  applicationId String   @map("application_id")
  attemptNo     Int      @map("attempt_no")
  result        String
  errorMessage  String?  @map("error_message")
  createdAt     DateTime @default(now()) @map("created_at")

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("submission_logs")
}
