# ───────────────────────────────────────────────────────────────
# InternSwipe – Environment Variables
# ───────────────────────────────────────────────────────────────
# Copy this file to .env.local  (Next.js will load it automatically)
#   cp .env.local.example .env.local
#
# Fill in credentials from the shared Supabase Cloud project.
# Ask your team lead (Bryan) if you need access.
# Values can be found in the Supabase dashboard under Settings.
# ───────────────────────────────────────────────────────────────

# PostgreSQL pooled connection string (Settings → Database → Connection string → Pooled)
DATABASE_URL=""

# PostgreSQL direct connection string, used by Prisma for migrations (Settings → Database → Connection string → Direct)
DIRECT_URL=""

# Supabase API URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=""

# Supabase anon key – safe to expose in the browser (Settings → API → anon public key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase service role key – NEVER expose in the browser (Settings → API → service_role key)
SUPABASE_SERVICE_ROLE_KEY=""
