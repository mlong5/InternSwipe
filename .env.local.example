# ───────────────────────────────────────────────────────────────
# InternSwipe – Environment Variables
# ───────────────────────────────────────────────────────────────
# Copy this file to .env.local  (Next.js will load it automatically)
#   cp .env.local.example .env.local
#
# OPTION A – Supabase Local Dev (recommended for development)
#   1. Install Docker Desktop: https://docs.docker.com/desktop
#   2. Run: npx supabase start
#   3. Copy the credentials from the output into this file.
#      The values below are the defaults from "npx supabase start":
#
# OPTION B – Shared Supabase Cloud Project
#   Ask your team lead (Bryan) for the cloud project credentials
#   and replace the values below.
# ───────────────────────────────────────────────────────────────

# PostgreSQL connection string (from Supabase local: Database URL)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Direct connection (same as DATABASE_URL for local dev; use the non-pooled URL for cloud)
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# Supabase API URL (from Supabase local: Project URL)
NEXT_PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"

# Supabase anon key – safe to expose in the browser (from: npx supabase status -o env → ANON_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0"

# Supabase service role key – NEVER expose in the browser (from: npx supabase status -o env → SERVICE_ROLE_KEY)
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU"
